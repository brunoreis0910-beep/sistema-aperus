# IMPORTANTE: Nunca commite este arquivo com valores reais!
# Este é apenas um template. Copie para .env e preencha com seus valores

# Django
SECRET_KEY=sua-secret-key-aqui-gere-uma-nova
DEBUG=False
ALLOWED_HOSTS=seu-dominio.com,www.seu-dominio.com

# Banco de Dados
DB_ENGINE=django.db.backends.mysql
DB_NAME=sistema_gerencial
DB_USER=seu_usuario
DB_PASSWORD=sua_senha_segura
DB_HOST=seu-host-mysql.com
DB_PORT=3306

# URLs
FRONTEND_URL=https://seu-dominio.com
BACKEND_URL=https://api.seu-dominio.com

# Email (opcional)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=seu-email@gmail.com
EMAIL_HOST_PASSWORD=sua-senha-de-app

# Google Gemini API (Para Assistente IA + Aprovação de Desconto)
# Obtenha sua chave GRATUITA em: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=sua-chave-gemini-aqui

# Google Cloud Text-to-Speech (Voz Neural2 pt-BR — substitui síntese robótica)
# Use a mesma chave do Gemini SE você habilitou a Cloud TTS API no mesmo projeto.
# Ou crie uma chave separada em: https://console.cloud.google.com/apis/credentials
# Habilite a API em: https://console.cloud.google.com/apis/library/texttospeech.googleapis.com
GOOGLE_CLOUD_TTS_API_KEY=sua-chave-tts-aqui

# ─── Aprovação de Desconto via WhatsApp ───────────────────────────────────
# O sistema tenta usar a Cloud API primeiro; só usa a Evolution como fallback.

# ── OPÇÃO 1: WhatsApp Cloud API (Meta Oficial — RECOMENDADO) ──────────────
# Vantagens: sem risco de banimento, 1.000 conversas gratuitas/mês
# Config: Meta for Developers → seu App → WhatsApp → Configuração da API
#
# Token Permanente de Sistema (permissões: whatsapp_business_messaging,
#   whatsapp_business_management). Caminho: App → Configurações → Usuários do Sistema
WHATSAPP_CLOUD_TOKEN=EAAxxxxxxxxxxxxxxxx
#
# Phone Number ID (visível em: Meta for Developers → WhatsApp → Configuração da API)
WHATSAPP_CLOUD_PHONE_ID=1234567890
#
# Token de verificação do Webhook — você inventa este valor e cadastra em:
#   Meta for Developers → WhatsApp → Webhook → Verificar token
# URL do webhook: https://SEU_SERVIDOR/api/aprovacao/webhook-cloud/
WHATSAPP_CLOUD_VERIFY_TOKEN=meu-token-secreto-qualquer

# ── OPÇÃO 2: Evolution API (fallback — usado se Cloud API não estiver configurado)
# Docs: https://doc.evolution-api.com
EVOLUTION_API_URL=http://localhost:8080
EVOLUTION_API_KEY=sua-api-key-evolution
EVOLUTION_INSTANCE=default

# Número do supervisor que irá receber e responder as aprovações
# Formato: apenas dígitos, com DDD.  Ex: 34987654321  (sem +55)
SUPERVISOR_WHATSAPP_PHONE=34987654321

# ── Listener WhatsApp Desktop (abre o app do WhatsApp para ler respostas) ───
# ATENÇÃO: quando True, o sistema abrirá o WhatsApp Desktop automaticamente
# a cada 15 segundos para ler a resposta do supervisor via PyAutoGUI.
# Deixe False (padrão) a menos que você queira usar esse método de leitura.
WHATSAPP_DESKTOP_LISTENER_ENABLED=False
# Intervalo em segundos entre cada verificação (padrão: 15)
WHATSAPP_DESKTOP_POLL_INTERVAL=15
