// Em: src/context/AuthContext.jsx

import React, { createContext, useState, useContext, useEffect } from 'react';
import axios from 'axios';
import { useNavigate, useLocation } from 'react-router-dom';

// 1. Cria o "Contexto" (o armazém de dados)
const AuthContext = createContext(null);

// 2. Define a URL da API
const API_BASE_URL = 'http://127.0.0.1:8000/api';

// 3. Cria o "Gerenciador" (AuthProvider)
export const AuthProvider = ({ children }) => {
  const [user, setUser] = useState(null); 
  const [permissions, setPermissions] = useState({}); 
  const [isLoading, setIsLoading] = useState(true); 
  const navigate = useNavigate();
  const location = useLocation();

  // Cria uma instância do Axios SÓ para este Contexto
  const axiosInstance = axios.create({
    baseURL: API_BASE_URL,
    timeout: 5000,
  });

  // Função de Logout (agora centralizada)
  const logout = () => {
    setUser(null);
    setPermissions({});
    localStorage.removeItem('accessToken');
    localStorage.removeItem('refreshToken');
    navigate('/login');
  };

  // Adiciona o Interceptor (o "porteiro" do Axios)
  axiosInstance.interceptors.request.use(
    (config) => {
      const token = localStorage.getItem('accessToken');
      if (token) {
        config.headers['Authorization'] = `Bearer ${token}`;
      }
      return config;
    },
    (error) => Promise.reject(error)
  );

  // Adiciona um Interceptor de RESPOSTA (para deslogar se o token expirar)
  axiosInstance.interceptors.response.use(
    (response) => response, 
    (error) => {
      if (error.response && error.response.status === 401) {
        console.error("Token expirado ou inválido. Deslogando...");
        logout();
      }
      return Promise.reject(error);
    }
  );

  // Função para buscar o usuário (usada no Login e no Refresh)
  const fetchUser = async () => {
    try {
      // Chama a nova API /api/usuarios/me/
      const response = await axiosInstance.get('/usuarios/me/');
      setUser(response.data);
      setPermissions(response.data.permissoes || {});
      return response.data; // Retorna o usuário
    } catch (error) {
      console.error("Falha ao buscar dados do usuário.", error);
      // Se der erro (ex: 401), o interceptor de resposta vai chamar o logout()
      throw error; // Joga o erro para o chamador
    }
  };

  // --- NOVA FUNÇÃO DE LOGIN ---
  const login = async (username, password) => {
    try {
      // 1. Pede o token (usando o axios normal, pois ainda não temos token)
      const response = await axios.post(`${API_BASE_URL}/token/`, {
        username: username,
        password: password
      });
      
      // 2. Salva o token
      localStorage.setItem('accessToken', response.data.access);
      localStorage.setItem('refreshToken', response.data.refresh);
      
      // 3. AGORA, busca os dados do usuário (com o token novo)
      const userData = await fetchUser(); 
      
      // 4. Navega para a página principal (ou de onde veio)
      const from = location.state?.from?.pathname || "/";
      navigate(from, { replace: true });
      
      return userData; // Sucesso
      
    } catch (error) {
      console.error('Erro no login:', error.response ? error.response.data : error.message);
      // Limpa tudo em caso de falha
      localStorage.removeItem('accessToken');
      localStorage.removeItem('refreshToken');
      setUser(null);
      setPermissions({});
      throw error; // Joga o erro para a LoginPage (para ela mostrar o alerta)
    }
  };


  // Roda esta função UMA VEZ quando o app carrega (para quem deu F5)
  useEffect(() => {
    const checkLoggedInUser = async () => {
      const token = localStorage.getItem('accessToken');
      if (!token) {
        setIsLoading(false);
        return; // Se não tem token, não faz nada
      }
      
      try {
        await fetchUser(); // Tenta buscar o usuário
      } catch (error) {
        // Se o token for inválido, o interceptor já chamou o logout
        console.log("Token antigo inválido.");
      } finally {
        setIsLoading(false);
      }
    };

    checkLoggedInUser();
  }, []); // O [] vazio garante que rode só uma vez

  // 4. Fornece os dados para todos os "filhos"
  const value = {
    user,
    permissions,
    isLoading,
    login, // <-- Expõe a nova função de login
    logout,
    axiosInstance 
  };

  return (
    <AuthContext.Provider value={value}>
      {children}
    </AuthContext.Provider>
  );
};

// 5. Cria o "Atalho" (o hook 'useAuth')
export const useAuth = () => {
  const context = useContext(AuthContext);
  if (context === undefined) {
    throw new Error('useAuth deve ser usado dentro de um AuthProvider');
  }
  return context;
};